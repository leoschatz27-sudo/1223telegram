import os
import sys

import requests


TELEGRAM_BOT_TOKEN = os.getenv("TELEGRAM_BOT_TOKEN", "8861517323:AAGiZVzMYnIjyP9wb7Rsa3x_AzHYL8FqzPk")
WEBHOOK_SECRET = os.getenv("WEBHOOK_SECRET", "cbc-webhook")

if len(sys.argv) != 2:
